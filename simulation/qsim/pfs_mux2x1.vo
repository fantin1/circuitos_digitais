`timescale 1 ps/ 1 ps

module pfs_mux2x1 (
	out,
	sel,
	e1,
	e0);
output 	out;
input 	sel;
input 	e1;
input 	e0;

// Design Ports Information
// out	=>  Location: PIN_M4,	 I/O Standard: 2.5 V,	 Current Strength: Default
// e1	=>  Location: PIN_N6,	 I/O Standard: 2.5 V,	 Current Strength: Default
// e0	=>  Location: PIN_C6,	 I/O Standard: 2.5 V,	 Current Strength: Default
// sel	=>  Location: PIN_B6,	 I/O Standard: 2.5 V,	 Current Strength: Default


wire gnd;
wire vcc;
wire unknown;

assign gnd = 1'b0;
assign vcc = 1'b1;
assign unknown = 1'bx;

tri1 devclrn;
tri1 devpor;
tri1 devoe;
wire \out~output_o ;
wire \e1~input_o ;
wire \sel~input_o ;
wire \e0~input_o ;
wire \inst~0_combout ;


// Location: IOOBUF_X8_Y0_N2
cycloneiv_io_obuf \out~output (
	.i(\inst~0_combout ),
	.oe(vcc),
	.seriesterminationcontrol(16'b0000000000000000),
	.devoe(devoe),
	.o(\out~output_o ),
	.obar());
// synopsys translate_off
defparam \out~output .bus_hold = "false";
defparam \out~output .open_drain_output = "false";
// synopsys translate_on

// Location: IOIBUF_X12_Y0_N1
cycloneiv_io_ibuf \e1~input (
	.i(e1),
	.ibar(gnd),
	.o(\e1~input_o ));
// synopsys translate_off
defparam \e1~input .bus_hold = "false";
defparam \e1~input .simulate_z_as = "z";
// synopsys translate_on

// Location: IOIBUF_X14_Y31_N8
cycloneiv_io_ibuf \sel~input (
	.i(sel),
	.ibar(gnd),
	.o(\sel~input_o ));
// synopsys translate_off
defparam \sel~input .bus_hold = "false";
defparam \sel~input .simulate_z_as = "z";
// synopsys translate_on

// Location: IOIBUF_X14_Y31_N1
cycloneiv_io_ibuf \e0~input (
	.i(e0),
	.ibar(gnd),
	.o(\e0~input_o ));
// synopsys translate_off
defparam \e0~input .bus_hold = "false";
defparam \e0~input .simulate_z_as = "z";
// synopsys translate_on

// Location: LCCOMB_X12_Y18_N0
cycloneiv_lcell_comb \inst~0 (
// Equation(s):
// \inst~0_combout  = (\sel~input_o  & (\e1~input_o )) # (!\sel~input_o  & ((\e0~input_o )))

	.dataa(gnd),
	.datab(\e1~input_o ),
	.datac(\sel~input_o ),
	.datad(\e0~input_o ),
	.cin(gnd),
	.combout(\inst~0_combout ),
	.cout());
// synopsys translate_off
defparam \inst~0 .lut_mask = 16'hCFC0;
defparam \inst~0 .sum_lutc_input = "datac";
// synopsys translate_on

assign out = \out~output_o ;

endmodule
