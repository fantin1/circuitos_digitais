// ck	=>  Location: PIN_M6,	 I/O Standard: 2.5 V,	 Current Strength: Default
// reset	=>  Location: PIN_L5,	 I/O Standard: 2.5 V,	 Current Strength: Default


wire gnd;
wire vcc;
wire unknown;

assign gnd = 1'b0;
assign vcc = 1'b1;
assign unknown = 1'bx;

tri1 devclrn;
tri1 devpor;
tri1 devoe;
wire \sq~output_o ;
wire \sand~output_o ;
