	.dataa(gnd),
	.datab(gnd),
	.datac(\eand~input_o ),
	.datad(\eq~input_o ),
	.cin(gnd),
	.combout(\inst3~combout ),
	.cout());
// synopsys translate_off
defparam inst3.lut_mask = 16'hF000;
defparam inst3.sum_lutc_input = "datac";
