wire \inst~q ;
wire \inst3~combout ;


// Location: IOOBUF_X8_Y0_N9
cycloneiv_io_obuf \sq~output (
	.i(\inst~q ),
	.oe(vcc),
	.seriesterminationcontrol(16'b0000000000000000),
	.devoe(devoe),
	.o(\sq~output_o ),
	.obar());
// synopsys translate_off
defparam \sq~output .bus_hold = "false";
defparam \sq~output .open_drain_output = "false";
// synopsys translate_on

// Location: IOOBUF_X10_Y0_N9
cycloneiv_io_obuf \sand~output (
