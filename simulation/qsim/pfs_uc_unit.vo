// synopsys translate_off
defparam \inst~0 .lut_mask = 16'h3CF0;
defparam \inst~0 .sum_lutc_input = "datac";
// synopsys translate_on

// Location: IOIBUF_X14_Y0_N8
cycloneiv_io_ibuf \reset~input (
