cycloneiv_lcell_comb \inst~0 (
// Equation(s):
// \inst~0_combout  = \inst~q  $ (((\eand~input_o  & \eq~input_o )))

	.dataa(gnd),
	.datab(\eand~input_o ),
	.datac(\inst~q ),
	.datad(\eq~input_o ),
